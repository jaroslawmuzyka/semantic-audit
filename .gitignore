# Katalog ze starą wersją systemu (nieużywany przez aplikację Streamlit)
semantic-os/

# Pliki konfiguracyjne zawierające wrażliwe klucze API
.streamlit/secrets.toml

# Środowisko wirtualne (jeśli utworzysz)
venv/
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Wygenerowane raporty (przykładowe/klienckie pliki wynikowe)
*.xlsx

# Lokalna konfiguracja uruchamiania podglądu (ścieżki specyficzne dla maszyny)
.claude/launch.json
